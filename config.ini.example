; MyBuddy example configuration.
; Search order:
; 1. config.ini beside MyBuddy.exe
; 2. %AppData%\MyBuddy\config.ini
; Save this file as UTF-8 without BOM.

[app]
; Global hotkey used to show the window.
; Simple supported forms: Ctrl+Alt+B, Ctrl+Shift+1, Alt+F6
; Default: Ctrl+Alt+B
globalHotKey=Ctrl+Alt+B

[toolbar]
; Optional top toolbar buttons, in display order, separated by ';'.
; If omitted, all [toolbar_button.*] sections are auto-discovered.
; Allowed icon values in this version: touch, proxy
; icon uses built-in button glyph names, not icon file paths.
; Allowed scope values: global, group, file
; buttons=touchNote;proxyCheck

[toolbar_button.touchNote]
; Shown in tooltip.
; title=Touch
; Allowed icon values in this version: touch, proxy
; icon=touch
; file scope means the command runs against the current file item.
; scope=file
; Example: update modified time so the current note rises to the top in mtime sort.
; command=C:\Tools\touch-note.cmd "{file}"

[toolbar_button.proxyCheck]
; title=Proxy
; icon=proxy
; global scope means the command does not require a selected note item.
; scope=global
; Example: run your proxy test-and-switch script.
; command=C:\Tools\check-and-switch-proxy.cmd

[default]
; New notes are first created as temporary drafts, then renamed from content
; after the editor exits.
; Maximum visible items per group.
; Integer >= 0. 0 means unlimited. Default: 5
maxItems=5
; Whether groups start expanded by default.
; Allowed values: 0, 1
defaultGroupExpanded=1
; Default item action unless overridden.
; For dirgroup/textgroup/todogroup this must reference [file_action.*].
; defaultItemAction=Edit
; Optional name for the delete menu item.
; If empty, no delete item is shown.
; deleteName=Delete
; Optional title override. If omitted, deleteName is used as the title.
; deleteTitle=Move to Trash
; Optional custom command used by the delete menu item.
; If omitted and deleteTitle is set, deletion moves the file to Recycle Bin.
; Available placeholders:
; {file} {dir} {name} {stem} {group} {group_title} {group_dir}
; deleteCommand=some-tool.exe "{file}"
; Default item context menu actions unless overridden.
; For dirgroup/textgroup/todogroup this must reference [file_action.*] sections.
; Use ';;' to insert a separator line in the menu.
itemActions=Edit;Reveal
; '=' replaces inherited values, '+=' appends, '-=' removes:
; itemActions+=Markpad;SoloMD
; itemActions-=Reveal
; Default group-header context menu actions unless overridden.
; For dirgroup this must reference [dir_action.*] sections.
; For textgroup/todogroup this must reference [file_action.*] sections.
; Use ';;' to insert a separator line in the menu.
groupActions=Terminal

[dirgroup]
; Default file patterns for dir groups, separated by ';'.
; Typical values: *.txt;*.md
filePatterns=*.txt;*.md
; filePatterns+=*.log
; filePatterns-=*.txt
; Default extension used when creating a new note in dir groups.
; Examples: .txt, .md
; If empty, the first writable extension from filePatterns is used.
createExtension=.md
; Default sort field for dir groups.
; Allowed values: name, ctime, mtime
sortBy=mtime
; Default sort direction for dir groups.
; Allowed values: asc, desc
sortOrder=desc
; Whether dir-group file items show file extensions by default.
; Allowed values: 0, 1. Default: 0
showExtensions=0
; Default dirgroup item action.
; Must reference [file_action.*].
; defaultItemAction=Edit
; Optional default name for the delete menu item in dir groups.
; deleteName=Delete
; Optional title override. If omitted, deleteName is used as the title.
; deleteTitle=Move to Trash
; Optional default command used by the delete menu item in dir groups.
; If omitted and deleteName/deleteTitle is set, deletion moves the file to Recycle Bin.
; deleteCommand=some-tool.exe "{file}"
; Default dirgroup item context actions.
; Must reference [file_action.*] sections.
itemActions=Edit;Reveal
; Default dirgroup group-header context actions.
; Must reference [dir_action.*] sections.
groupActions=Terminal

[textgroup]
; Default sort field for text groups.
; Allowed values: line, name, ctime, mtime
sortBy=line
; Default sort direction for text groups.
; Allowed values: asc, desc
sortOrder=asc
; Default textgroup item action.
; If omitted, item click has no default action.
; defaultItemAction=View
; Optional default name for the delete menu item for text/todo-group source files.
; deleteName=Delete
; Optional title override. If omitted, deleteName is used as the title.
; deleteTitle=Move to Trash
; Optional default command used by the delete menu item for text/todo-group source files.
; If omitted and deleteName/deleteTitle is set, deletion moves the source file to Recycle Bin.
; deleteCommand=some-tool.exe "{file}"
; Default textgroup item context actions.
; If omitted, groupActions is used.
; Must reference [file_action.*] sections.
itemActions=Reveal
; Default textgroup group-header context actions.
; Must reference [file_action.*] sections.
groupActions=Reveal

[todogroup]
; Default sort field for todo groups.
; Allowed values: line, name, ctime, mtime
sortBy=line
; Default sort direction for todo groups.
; Allowed values: asc, desc
sortOrder=asc
; Default todogroup item action.
; If omitted, item click has no default action.
; defaultItemAction=Edit
; Optional default name for the delete menu item for todo-group source files.
; deleteName=Delete
; Optional default command used by the delete menu item for todo-group source files.
; deleteCommand=some-tool.exe "{file}"
; Default todogroup item context actions.
; If omitted, groupActions is used.
itemActions=Reveal
; Default todogroup group-header context actions.
; Must reference [file_action.*] sections.
groupActions=Reveal

[file_action.Edit]
; Menu text shown to the user.
title=Edit
; Full command line.
; Available placeholders:
; {file} {dir} {name} {stem} {group} {group_title} {group_dir}
command=notepad.exe "{file}"

[file_action.Reveal]
title=Open Folder
command=explorer.exe /select,"{file}"

[dir_action.Terminal]
; If omitted, the action id "Terminal" is used as the title.
command=wt.exe -d "{group_dir}"

[dirgroup.inbox]
; Group title shown in the main list.
title=Inbox
; Absolute directory path for this group.
; Required.
path=C:\Users\USERNAME\Documents\Notes\Inbox
; Optional per-group override. Allowed values: 0, 1
; expanded=1
; Optional per-group override for whether dir-group file items show file extensions.
; Allowed values: 0, 1
; showExtensions=0
; Optional per-group override for file patterns.
; filePatterns=*.txt;*.md
; Optional per-group override for new-note extension.
; Examples: .txt, .md
; createExtension=.txt
; Optional per-group override for max visible items.
; 0 means unlimited.
; maxItems=5
; Optional per-group override for sort field.
; Allowed values: name, ctime, mtime
; sortBy=mtime
; Optional per-group override for sort direction.
; Allowed values: asc, desc
; sortOrder=desc
; Action id used when clicking a file item or after creating a new file.
; Must reference a [file_action.*] section.
; defaultItemAction=Edit
; Optional per-group override for the delete menu item name.
; If empty, no delete item is shown for this group's file items.
; deleteName=Delete
; Optional per-group override for the menu text. If omitted, deleteName is used.
; deleteTitle=Move to Trash
; Optional per-group override for the delete menu item command.
; If omitted and deleteName/deleteTitle is set, deletion moves the target file to Recycle Bin.
; deleteCommand=some-tool.exe "{file}"
; Additional item context menu actions, separated by ';'.
; Must reference [file_action.*] sections.
; itemActions=Edit;Reveal
; Group-header context menu actions, separated by ';'.
; Must reference [dir_action.*] sections.
; groupActions=Terminal
; itemActions+=SoloMD
; itemActions-=Reveal

[textgroup.todo_lines]
; Path points to one text file for text groups.
path=C:\Users\USERNAME\Documents\Notes\todo.txt
; text groups usually keep file order.
sortBy=line
; If omitted, item click has no default action.
; defaultItemAction=Edit
deleteName=Delete
; deleteCommand=some-tool.exe "{file}"
; If omitted, groupActions is used.
; itemActions=Reveal
; itemActions+=Markpad
; groupActions-=Reveal
groupActions=Reveal

[todogroup.tasks]
; Path points to one todo.txt file for todo groups.
path=C:\Users\USERNAME\Documents\Notes\todo.txt
; todo groups usually keep file order.
sortBy=line
; If omitted, item click has no default action.
; defaultItemAction=Edit
deleteName=Delete
; deleteCommand=some-tool.exe "{file}"
; If omitted, groupActions is used.
; itemActions=Reveal
groupActions=Reveal

[dirgroup.work]
; If omitted, the group id "work" is used as the title.
title=Work
path=C:\Users\USERNAME\Documents\Notes\Work
; This group only shows markdown files.
filePatterns=*.md
createExtension=.md
maxItems=8
sortBy=name
sortOrder=asc
showExtensions=0
defaultItemAction=Edit
deleteName=Trash
; deleteCommand=some-tool.exe "{file}"
itemActions=Edit;Reveal
groupActions=Terminal
