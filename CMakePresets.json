{
  "version": 6,
  "configurePresets": [
    {
      "name": "vs-x64",
      "displayName": "Visual Studio x64",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs-x64-debug",
      "configurePreset": "vs-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs-x64-release",
      "configurePreset": "vs-x64",
      "configuration": "Release"
    }
  ]
}
